model User {
  id        String     @id @unique @default(cuid())
  email     String     @unique
  password  String
  name      String
  role      Role       @default(CUSTOMER)
  status    UserStatus @default(ACTIVE)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  gearItems GearItem[]
  reviews   Review[]

  @@map("users")
}
